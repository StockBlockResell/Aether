<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Aether Shell — Never Die Again</title>
<link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700;900&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;1,9..40,300&display=swap" rel="stylesheet">
<style>
:root {
  --black:    #020408;
  --deep:     #060c14;
  --card:     #0a1220;
  --border:   #0e2040;
  --blue:     #2af4ff;
  --blue-dim: #0a8fa0;
  --blue-glow:rgba(42,244,255,0.18);
  --white:    #f0f8ff;
  --muted:    #5a7a9a;
  --danger:   #ff3d6e;
  --gold:     #f0c060;
}

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html { scroll-behavior: smooth; }
body { font-family: 'DM Sans', sans-serif; background: var(--black); color: var(--white); overflow-x: hidden; cursor: none; }

/* ── Cursor ── */
#cursor { position: fixed; width: 12px; height: 12px; background: var(--blue); border-radius: 50%; pointer-events: none; z-index: 99999; transform: translate(-50%,-50%); transition: width 0.2s, height 0.2s; mix-blend-mode: screen; }
#cursor-ring { position: fixed; width: 36px; height: 36px; border: 1px solid var(--blue); border-radius: 50%; pointer-events: none; z-index: 99998; transform: translate(-50%,-50%); transition: width 0.3s, height 0.3s; opacity: 0.5; }

/* ── Grid BG ── */
.grid-bg { position: fixed; inset: 0; z-index: 0; background-image: linear-gradient(rgba(42,244,255,0.025) 1px, transparent 1px), linear-gradient(90deg, rgba(42,244,255,0.025) 1px, transparent 1px); background-size: 60px 60px; animation: gridScroll 20s linear infinite; }
@keyframes gridScroll { from { background-position: 0 0; } to { background-position: 60px 60px; } }

/* ── Nav ── */
nav { position: fixed; top: 0; left: 0; right: 0; z-index: 1000; padding: 20px 6%; display: flex; align-items: center; justify-content: space-between; background: rgba(2,4,8,0.9); backdrop-filter: blur(12px); border-bottom: 1px solid var(--border); }
.nav-logo { font-family: 'Orbitron', monospace; font-weight: 900; font-size: 1.1rem; letter-spacing: 4px; color: var(--blue); text-decoration: none; }
.nav-links { display: flex; gap: 36px; list-style: none; }
.nav-links a { font-size: 0.75rem; letter-spacing: 2px; text-transform: uppercase; color: var(--muted); text-decoration: none; transition: color 0.2s; }
.nav-links a:hover { color: var(--blue); }

/* ── Hero ── */
#hero { position: relative; z-index: 1; min-height: 100vh; display: flex; flex-direction: column; align-items: center; justify-content: center; text-align: center; padding: 120px 6% 80px; }
.hero-title { font-family: 'Orbitron', monospace; font-size: clamp(3.5rem, 10vw, 7rem); font-weight: 900; line-height: 0.9; margin-bottom: 10px; }
.hero-sub { font-size: 1.1rem; color: var(--muted); max-width: 600px; margin-top: 20px; }
.hero-sub strong { color: var(--white); }

/* ── Stats ── */
.stats-bar { position: relative; z-index: 1; background: var(--card); border-top: 1px solid var(--border); border-bottom: 1px solid var(--border); padding: 40px 6%; display: grid; grid-template-columns: repeat(3, 1fr); text-align: center; }
.stat-num { font-family: 'Orbitron', monospace; font-size: 2.5rem; color: var(--blue); }
.stat-label { font-size: 0.7rem; letter-spacing: 2px; text-transform: uppercase; color: var(--muted); margin-top: 10px; }

/* ── Team Section ── */
#team { padding: 80px 6%; text-align: center; }
.team-grid { display: flex; justify-content: center; gap: 40px; margin-top: 40px; flex-wrap: wrap; }
.team-card { background: var(--card); padding: 30px; border: 1px solid var(--border); width: 250px; }
.team-name { font-family: 'Orbitron', monospace; color: var(--blue); margin-bottom: 5px; }
.team-role { font-size: 0.8rem; color: var(--muted); text-transform: uppercase; }

/* ── Pricing ── */
#pricing { padding: 100px 6%; text-align: center; }
.price-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 30px; max-width: 800px; margin: 40px auto; }
.price-card { background: var(--card); padding: 40px; border: 1px solid var(--border); text-align: left; position: relative; transition: transform 0.3s; }
.price-card:hover { transform: translateY(-10px); border-color: var(--blue); }
.price-card.featured { border-color: var(--blue); background: linear-gradient(145deg, #0a1220, #0d1b2e); }
.price-tag { font-family: 'Orbitron', monospace; font-size: 2rem; color: var(--white); margin: 15px 0; }
.price-features { list-style: none; font-size: 0.85rem; color: var(--muted); line-height: 2; margin-bottom: 30px; }
.price-features li::before { content: '✓ '; color: var(--blue); }

/* ── Buttons ── */
.btn-primary { font-family: 'Orbitron', monospace; padding: 16px 32px; background: var(--blue); color: var(--black); border: none; cursor: pointer; font-weight: 700; text-transform: uppercase; clip-path: polygon(10px 0, 100% 0, calc(100% - 10px) 100%, 0 100%); transition: 0.3s; }
.btn-primary:hover { box-shadow: 0 0 20px var(--blue); }

/* ── Modal ── */
#modal { display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.9); z-index: 10000; align-items: center; justify-content: center; }
.modal-content { background: var(--card); padding: 50px; border: 1px solid var(--blue); text-align: center; max-width: 400px; }

/* Reveal Animation */
.reveal { opacity: 0; transform: translateY(30px); transition: 0.8s all ease; }
.reveal.visible { opacity: 1; transform: translateY(0); }

@media (max-width: 768px) { .stats-bar, .price-grid { grid-template-columns: 1fr; } }
</style>
</head>
<body>

